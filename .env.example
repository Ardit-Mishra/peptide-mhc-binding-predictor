# Database Configuration
# Replace with your actual database URL
DATABASE_URL=postgresql://username:password@hostname:port/database

# Session Security
# Generate a strong secret key for session management
SESSION_SECRET=your-secure-session-secret-key-here

# Google Drive API (Optional - for model file management)
# Create service account credentials from Google Cloud Console
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"..."}

# Application Settings
NODE_ENV=development
PORT=5000

# Development Settings
LOG_LEVEL=info
HEALTH_CHECK_TIMEOUT=5000

# External API Keys (if integrating with real databases)
# IEDB_API_KEY=your_iedb_api_key
# UNIPROT_API_KEY=your_uniprot_api_key

# Performance Settings
WEB_CONCURRENCY=1
MAX_OLD_SPACE_SIZE=512

# Frontend Build Settings (for production)
VITE_API_URL=http://localhost:5000